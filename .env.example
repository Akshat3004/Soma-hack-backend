# Server
PORT=4000
NODE_ENV=development

# PostgreSQL — either set DATABASE_URL, or the individual PG* vars below
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aib_pulse

# Set to true for managed/remote Postgres that requires SSL (Render, Heroku, Supabase)
PGSSL=false

# Used only if DATABASE_URL is not set
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=aib_pulse

# Upstream mock PCC API (used by the ingestion pipeline)
PCC_BASE_URL=https://hackathon.prod.pulsefoundry.ai
